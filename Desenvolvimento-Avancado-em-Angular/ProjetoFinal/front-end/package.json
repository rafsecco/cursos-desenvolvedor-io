{
  "name": "front-end",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prd": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:utils": "ng test --include \"src/app/utils/**/*.spec.ts\"",
    "test:services": "ng test --include \"src/app/services/**/*.spec.ts\"",
    "test:conta": "ng test --include \"src/app/conta/**/*.spec.ts\"",
    "test:produto": "ng test --include \"src/app/produto/**/*.spec.ts\"",
    "test:fornecedor": "ng test --include \"src/app/fornecedor/**/*.spec.ts\"",
    "serve:ssr:front-end": "node dist/front-end/server/server.mjs",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "e2e:produto": "playwright test --config=e2e/playwright.config.ts e2e/src/cadastro-produto/app.cadastro-produto.spec.ts",
    "e2e:produto:headed": "playwright test --config=e2e/playwright.config.ts e2e/src/cadastro-produto/app.cadastro-produto.spec.ts --headed"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "express": "^5.1.0",
    "ngx-mask": "^21.0.1",
    "ngx-spinner": "^21.1.0",
    "ngx-toastr": "^20.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
